{
    "name": "componenta/middleware-factory",
    "description": "PSR-15 middleware factory integration for Componenta",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/arrayable": "^1.0",
        "componenta/di": "^1.0",
        "componenta/http-responder": "^1.0",
        "componenta/pipeline": "^1.0",
        "componenta/reflection": "^1.0",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-middleware": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\Http\\Middleware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\Http\\Middleware\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\Http\\Middleware\\ConfigProvider"
            ]
        }
    }
}
